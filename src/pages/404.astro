---
// SPDX-License-Identifier: MIT
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page not found" showNavigation={false} locale="en">
  <section
    class="flex flex-col items-center justify-center text-center rounded-[28px] p-10 md:p-16 shadow-sm backdrop-blur min-h-[50vh]"
    style="background: var(--glass); border: 1px solid var(--glass-border);"
  >
    <div class="text-7xl md:text-8xl font-black text-emerald-600 dark:text-emerald-400 leading-none select-none">404</div>

    <div class="lang-en">
      <h1 class="mt-6 text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100">Page not found</h1>
      <p class="mt-3 max-w-md text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
    </div>

    <div class="lang-de">
      <h1 class="mt-6 text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100">Seite nicht gefunden</h1>
      <p class="mt-3 max-w-md text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
        Die gesuchte Seite existiert nicht oder wurde verschoben.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a
        class="rounded-xl border px-5 py-2.5 text-sm font-semibold transition hover:-translate-y-0.5 hover:shadow-lg backdrop-blur inline-flex items-center gap-2"
        style="background: var(--glass); border-color: var(--glass-border);"
        href="/"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="lang-en">Back to Home</span>
        <span class="lang-de">Zur Startseite</span>
      </a>
      <a
        class="rounded-xl border px-5 py-2.5 text-sm font-semibold transition hover:-translate-y-0.5 hover:shadow-lg backdrop-blur inline-flex items-center gap-2"
        style="background: var(--glass); border-color: var(--glass-border);"
        href="/projects"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="lang-en">View Projects</span>
        <span class="lang-de">Projekte ansehen</span>
      </a>
    </div>
  </section>
</BaseLayout>
