---
// SPDX-License-Identifier: MIT
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { localePath } from "../../../utils/i18n";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "vi" } },
  ];
}

const locale = (Astro.params.locale as string) || "en";
const t = (en: string, vi: string) => (locale === "vi" ? vi : en);

const allProjects = await getCollection("projects");
const projects = allProjects.filter((p) => p.data.ready !== false);
// Featured first, then by pid within each group
const sorted = [...projects].sort((a, b) => {
  const fa = a.data.featured ? 0 : 1;
  const fb = b.data.featured ? 0 : 1;
  if (fa !== fb) return fa - fb;
  return (a.data.pid ?? 999999) - (b.data.pid ?? 999999);
});
const toSlug = (p) =>
  String(p.data.slug ?? p.id)
    .replace(/\/+$/g, "")
    .replace(/\.mdx?$/i, "");

const categories = [...new Set(projects.map((p) => p.data.category ?? "other"))].sort();
const categoryLabels: Record<string, { en: string; vi: string }> = {
  automation: { en: "Automation", vi: "Automation" },
  tooling: { en: "Tooling", vi: "Tooling" },
  "open-source": { en: "Open Source", vi: "Open Source" },
  integration: { en: "Integration", vi: "Integration" },
  research: { en: "Research", vi: "Research" },
  "self-hosted": { en: "Self-Hosted", vi: "Self-Hosted" },
  other: { en: "Other", vi: "Other" },
};

const toneOf = (tags) => {
  const tArr = (tags ?? []).map((x) => String(x).toLowerCase());
  if (tArr.includes("ongoing") || tArr.includes("active")) return "tone-a2";
  if (tArr.includes("lab") || tArr.includes("prototype")) return "tone-a3";
  return "tone-a1";
};
---

<BaseLayout title={t("Projects", "Dự án")} showNavigation={false} locale={locale}>
  <section
    class="archive-shell relative w-full rounded-[32px] border p-6 md:p-10 overflow-hidden"
    style="background: var(--glass); border-color: var(--glass-border);"
  >
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.035] dark:opacity-[0.05]"
      style="
        background-image:
          linear-gradient(to right, rgba(255,255,255,.7) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(255,255,255,.7) 1px, transparent 1px);
        background-size: 42px 42px;
        mix-blend-mode: overlay;
      "
    ></div>

    <div
      class="pointer-events-none absolute -top-40 -left-40 h-[520px] w-[520px] rounded-full blur-3xl opacity-40"
      style="background: radial-gradient(circle, var(--a2), transparent 60%);"
    ></div>
    <div
      class="pointer-events-none absolute -bottom-52 -right-52 h-[620px] w-[620px] rounded-full blur-3xl opacity-35"
      style="background: radial-gradient(circle, var(--a1), transparent 60%);"
    ></div>

    <header class="relative z-10 mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3">
          <span class="signal-dot" aria-hidden="true"></span>
          <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-zinc-500 dark:text-zinc-400">
            {t("Projects", "Dự án")}
          </span>
        </div>

        <h1 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          {t("My Work", "Các dự án của mình")}
        </h1>

        <p class="mt-3 text-base text-zinc-600 dark:text-zinc-400">
          {t("Projects, experiments, and open-source contributions — built to ship.", "Các dự án, thử nghiệm và đóng góp mã nguồn mở — tập trung vào sản phẩm có thể triển khai thực tế.")}
        </p>
      </div>

      <a href={localePath("/", locale)} class="return-btn">{t("← Home", "← Trang chủ")}</a>
    </header>

    {/* ── Category filter ─────────────────── */}
    <div class="relative z-10 mb-8 flex flex-wrap gap-2" id="categoryFilter">
      <button
        data-cat="all"
        class="cat-btn cat-btn--active"
        type="button"
      >
        {t("All", "Tất cả")}
      </button>
      {categories.map((cat) => (
        <button
          data-cat={cat}
          class="cat-btn"
          type="button"
        >
          {categoryLabels[cat]?.[locale] ?? cat}
        </button>
      ))}
    </div>

    <div id="projectsGrid" class="relative z-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((p) => {
        const cover = p.data.coverImage;
        const logo = p.data.image;
        const slug = toSlug(p);
        const tone = toneOf(p.data.tags);
        const tagsStr = (p.data.tags ?? []).map((tg) => String(tg).toLowerCase()).join("|");
        const gallery = p.data.gallery ?? [];
        const hasCover = !!cover;
        const titleLocal = locale === "vi" ? (p.data.title_vi || p.data.title) : p.data.title;
        const descLocal = locale === "vi" ? (p.data.description_vi || p.data.description) : p.data.description;
        const isFeatured = !!p.data.featured;
        const cat = p.data.category ?? "other";
        const catLabel = categoryLabels[cat]?.[locale] ?? cat;

        return (
          <a
            href={localePath(`/projects/${slug}/`, locale)}
            data-tags={tagsStr}
            data-category={cat}
            aria-label={titleLocal}
            class={`card group relative overflow-hidden rounded-2xl border p-1 transition-all duration-300 hover:-translate-y-1 ${tone} ${isFeatured ? 'card--featured' : ''}`}
            style="border-color: var(--glass-border);"
          >
            <div class="card-inner rounded-[14px] overflow-hidden">
              <div class={`media-wrap ${hasCover ? 'has-cover' : 'has-logo'}`}>
                {hasCover ? (
                  <>
                    <img
                      src={cover}
                      alt={titleLocal}
                      class="media-cover"
                      loading="lazy"
                      decoding="async"
                    />
                    {gallery.length > 0 && gallery.map((src, i) => (
                      <img
                        src={src}
                        alt=""
                        class="media-hover"
                        data-gallery-index={i}
                        loading="lazy"
                      />
                    ))}
                  </>
                ) : logo ? (
                  <img
                    src={logo}
                    alt={titleLocal}
                    class="media-logo"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="media-empty">
                    <div class="font-mono text-xs opacity-60">{t("NO_PREVIEW", "KHÔNG_CÓ_XEM_TRƯỚC")}</div>
                  </div>
                )}

                <div class="sweep" aria-hidden="true"></div>

                {isFeatured && (
                  <div class="featured-badge">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    <span>{t("Featured", "Nổi bật")}</span>
                  </div>
                )}
              </div>

              <div class="p-4">
                <div class="mb-2 flex items-center gap-2">
                  <span class="cat-chip">{catLabel}</span>
                </div>
                <h2 class="text-lg font-bold text-zinc-900 dark:text-zinc-100 break-words">
                  {titleLocal}
                </h2>

                <p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">
                  {descLocal}
                </p>

                <div class="mt-3 flex flex-wrap items-center gap-x-1.5 gap-y-1">
                  {(p.data.tags ?? []).slice(0, 4).map((tg, i) => (
                    <>
                      {i > 0 && <span class="tag-sep">·</span>}
                      <span class="tag">{tg}</span>
                    </>
                  ))}
                </div>

                <div class="mt-4 flex items-center justify-between gap-3">
                  <span class="text-sm font-semibold text-zinc-800 dark:text-zinc-200 group-hover:underline">
                    {t("View details →", "Xem chi tiết →")}
                  </span>

                  {(p.data.links?.[0]?.url) ? (
                    <span class="font-mono text-[10px] opacity-50">↗</span>
                  ) : null}
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <script is:inline>
      // Tag filter (from URL ?tag=...)
      const params = new URLSearchParams(window.location.search);
      const tag = params.get("tag");
      if (tag) {
        const want = tag.toLowerCase();
        document.querySelectorAll("#projectsGrid [data-tags]").forEach((card) => {
          const tags = (card.getAttribute("data-tags") || "").split("|").filter(Boolean);
          card.classList.toggle("hidden", !tags.includes(want));
        });
      }

      // Category filter buttons
      document.querySelectorAll("#categoryFilter .cat-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const cat = btn.getAttribute("data-cat");
          document.querySelectorAll("#categoryFilter .cat-btn").forEach((b) =>
            b.classList.remove("cat-btn--active")
          );
          btn.classList.add("cat-btn--active");
          document.querySelectorAll("#projectsGrid [data-category]").forEach((card) => {
            card.classList.toggle("hidden", cat !== "all" && card.getAttribute("data-category") !== cat);
          });
        });
      });

      // Gallery slideshow on hover
      document.querySelectorAll("#projectsGrid .card").forEach((card) => {
        const slides = card.querySelectorAll(".media-hover");
        if (slides.length === 0) return;

        let idx = 0;
        let timer = null;

        function showSlide(i) {
          slides.forEach((s) => s.classList.remove("slide-active"));
          slides[i].classList.add("slide-active");
        }

        card.addEventListener("mouseenter", () => {
          idx = 0;
          showSlide(idx);
          if (slides.length > 1) {
            timer = setInterval(() => {
              idx = (idx + 1) % slides.length;
              showSlide(idx);
            }, 1000);
          }
        });

        card.addEventListener("mouseleave", () => {
          if (timer) { clearInterval(timer); timer = null; }
          slides.forEach((s) => s.classList.remove("slide-active"));
          idx = 0;
        });
      });
    </script>

    <style is:global>
      .signal-dot{
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--a2);
        box-shadow:
          0 0 0 2px rgba(255,255,255,.10),
          0 0 14px color-mix(in srgb, var(--a2) 75%, transparent),
          0 0 34px color-mix(in srgb, var(--a2) 45%, transparent);
        animation: lightningPulse 1.8s ease-in-out infinite;
      }

      @keyframes lightningPulse{
        0%, 100% {
          transform: scale(1);
          box-shadow:
            0 0 0 2px rgba(255,255,255,.10),
            0 0 14px color-mix(in srgb, var(--a2) 75%, transparent),
            0 0 34px color-mix(in srgb, var(--a2) 45%, transparent);
        }
        50% {
          transform: scale(1.18);
          box-shadow:
            0 0 0 6px rgba(255,255,255,.06),
            0 0 22px color-mix(in srgb, var(--a2) 85%, transparent),
            0 0 60px color-mix(in srgb, var(--a2) 55%, transparent);
        }
      }

      .return-btn{
        border: 1px solid var(--glass-border);
        background: rgba(255,255,255,.10);
        padding: 10px 14px;
        border-radius: 16px;
        font-size: 14px;
        font-weight: 700;
        transition: transform .15s ease, background .15s ease;
      }
      .return-btn:hover{ transform: translateY(-2px); background: rgba(255,255,255,.14); }

      .card{
        background: rgba(255,255,255,.06);
        box-shadow: 0 16px 48px rgba(0,0,0,.10);
        transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
      }
      .card:hover{
        box-shadow: 0 24px 64px rgba(0,0,0,.16);
      }

      .card-inner{
        background: rgba(255,255,255,.06);
        backdrop-filter: blur(12px);
      }
      .dark .card-inner{
        background: rgba(10,10,10,.35);
      }

      /* ── Media area ────────────────────────── */
      .media-wrap{
        height: 220px;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid rgba(0,0,0,.06);
      }
      .dark .media-wrap{
        border-bottom-color: rgba(255,255,255,.08);
      }

      /* Screenshot / cover mode */
      .media-wrap.has-cover{
        background: #18181b;
      }

      .media-cover{
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        transition: transform .5s cubic-bezier(.2,.8,.2,1), opacity .4s ease;
      }
      .card:hover .media-cover{
        transform: scale(1.03);
      }

      /* Gallery hover swap */
      .media-hover{
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: #18181b;
        opacity: 0;
        transition: opacity .45s ease;
        pointer-events: none;
      }
      .media-hover.slide-active{
        opacity: 1;
      }
      .card:hover:has(.media-hover) .media-cover{
        opacity: 0;
        transform: none;
      }

      /* Logo-only mode — clean gradient background */
      .media-wrap.has-logo{
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 36px;
        background: linear-gradient(145deg, #f9fafb 0%, #f1f5f9 60%, #ecfdf5 100%);
      }
      .dark .media-wrap.has-logo{
        background: linear-gradient(145deg, #18181b 0%, #1c1c22 60%, #121e1a 100%);
      }

      .media-logo{
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        filter: drop-shadow(0 8px 28px rgba(0,0,0,.10));
        transition: transform .4s ease;
      }
      .dark .media-logo{
        filter: drop-shadow(0 8px 28px rgba(0,0,0,.35));
      }
      .card:hover .media-logo{
        transform: scale(1.04);
      }

      .media-empty{
        width: 100%;
        height: 100%;
        display: grid;
        place-items: center;
        background: linear-gradient(145deg, #f9fafb, #f1f5f9);
        color: rgba(113,113,122,.6);
      }
      .dark .media-empty{
        background: linear-gradient(145deg, #18181b, #1c1c22);
        color: rgba(161,161,170,.5);
      }

      /* ── Sweep highlight ───────────────────── */
      .sweep{
        position: absolute;
        inset: -30% -40%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.08), transparent);
        transform: translateX(-40%) rotate(12deg);
        opacity: 0;
        transition: opacity .2s ease;
        pointer-events: none;
      }
      .card:hover .sweep{
        opacity: .9;
        animation: sweep 1.1s ease forwards;
      }
      @keyframes sweep{
        from { transform: translateX(-55%) rotate(12deg); }
        to { transform: translateX(55%) rotate(12deg); }
      }

      /* ── Tags — subtle inline text ──────────── */
      .tag{
        font-size: 11px;
        font-weight: 500;
        font-family: ui-monospace, SFMono-Regular, monospace;
        color: rgba(113,113,122,.75);
        line-height: 1;
      }
      .dark .tag{
        color: rgba(161,161,170,.65);
      }
      .tag-sep{
        font-size: 11px;
        color: rgba(113,113,122,.35);
        line-height: 1;
      }
      .dark .tag-sep{
        color: rgba(161,161,170,.3);
      }

      /* ── Tone accents ──────────────────────── */
      .tone-a1:hover{ border-color: color-mix(in srgb, var(--a1) 55%, var(--glass-border)); }
      .tone-a2:hover{ border-color: color-mix(in srgb, var(--a2) 55%, var(--glass-border)); }
      .tone-a3:hover{ border-color: color-mix(in srgb, var(--a3) 55%, var(--glass-border)); }

      .tone-a2 .card-inner{ box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset, 0 0 28px color-mix(in srgb, var(--a2) 18%, transparent); }
      .tone-a3 .card-inner{ box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset, 0 0 28px color-mix(in srgb, var(--a3) 16%, transparent); }

      /* ── Featured badge ────────────────────── */
      .featured-badge{
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 5;
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px 4px 8px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #fbbf24;
        background: rgba(0,0,0,.55);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(251,191,36,.25);
        pointer-events: none;
      }
      .card--featured{
        border-color: rgba(251,191,36,.25);
      }
      .card--featured:hover{
        border-color: rgba(251,191,36,.45);
      }

      /* ── Category chip on cards ────────────── */
      .cat-chip{
        display: inline-block;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 600;
        font-family: ui-monospace, SFMono-Regular, monospace;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        background: rgba(113,113,122,.10);
        color: rgba(113,113,122,.85);
        line-height: 1.6;
      }
      .dark .cat-chip{
        background: rgba(161,161,170,.12);
        color: rgba(161,161,170,.75);
      }

      /* ── Category filter bar ───────────────── */
      .cat-btn{
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid var(--glass-border);
        background: rgba(255,255,255,.06);
        color: rgba(113,113,122,.85);
        cursor: pointer;
        transition: all .2s ease;
      }
      .dark .cat-btn{
        color: rgba(161,161,170,.75);
      }
      .cat-btn:hover{
        background: rgba(255,255,255,.12);
        transform: translateY(-1px);
      }
      .cat-btn--active{
        background: var(--a2);
        color: #fff;
        border-color: var(--a2);
      }
      .cat-btn--active:hover{
        background: var(--a2);
        color: #fff;
      }
    </style>
  </section>
</BaseLayout>
