---
// SPDX-License-Identifier: MIT
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
import OrbHero from "../components/OrbHero.astro";
import { getCollection } from "astro:content";
import LikeFooter from "../components/LikeFooter.astro";
import { localePath, getAlternatePath } from "../utils/i18n";

const {
  title = "Your Name • Portfolio",
  description = "Developer portfolio — modern, fast, and fully customizable Astro theme with i18n, dark mode, and project showcases.",
  locale = "en",
  ogImagePath = "/images/og.png",
  showNavigation = true,
  jsonLd = null,
} = Astro.props;

const allProjects = await getCollection("projects");
const projects = allProjects.filter((p) => p.data.ready !== false);
const tags = Array.from(new Set(projects.flatMap((p) => p.data.tags ?? []))).sort((a, b) =>
  a.localeCompare(b)
);

const site = Astro.site ?? new URL("https://example.com");
const pathname = Astro.url.pathname;
const canonicalURL = new URL(pathname, site).href;
const ogImageURL = new URL(ogImagePath, site).href;

const alt = getAlternatePath(pathname);
const enURL = new URL(locale === "de" ? alt.path : pathname, site).href;
const deURL = new URL(locale === "de" ? pathname : alt.path, site).href;

const t = (en: string, de: string) => (locale === "de" ? de : en);
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="de" href={deURL} />
    <link rel="alternate" hreflang="x-default" href={enURL} />
    <link rel="icon" href="/favico.png" sizes="any" />

    <script is:inline>
      // Blocking: apply saved theme before first paint to prevent FOUC
      (function() {
        var theme = localStorage.getItem("theme") || "light";
        if (theme === "dark") document.documentElement.classList.add("dark");
      })();
    </script>

    <script is:inline>
      // Locale detection: redirect German-locale browsers to /de/ on first visit
      (function() {
        if (localStorage.getItem("locale-pref")) return;
        var lang = (navigator.language || "").split("-")[0];
        localStorage.setItem("locale-pref", lang === "de" ? "de" : "en");
        if (lang === "de" && !location.pathname.startsWith("/de")) {
          var p = location.pathname === "/" ? "/de/" : "/de" + location.pathname;
          location.replace(p + location.search + location.hash);
        }
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:secure_url" content={ogImageURL} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Portfolio preview" />
    <meta property="og:locale" content={locale === "de" ? "de_DE" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "de" ? "en_US" : "de_DE"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <style is:global>
      .tag-dd-link::after { content: none !important; }
      .no-scrollbar{
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .no-scrollbar::-webkit-scrollbar{
        width: 0;
        height: 0;
      }

      .header-icon {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
      }
      .header-icon > * {
        width: 100%;
        height: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .journey-overlap {
        margin-top: -70px;
      }
      @media (max-width: 768px) {
        .journey-overlap {
          margin-top: -40px;
        }
      }

      :focus-visible {
        outline: 2px solid rgba(20,184,166,0.8);
        outline-offset: 2px;
        border-radius: 4px;
      }

      .skip-link {
        position: absolute;
        top: -100%;
        left: 16px;
        z-index: 9999;
        padding: 8px 16px;
        background: #14b8a6;
        color: #fff;
        border-radius: 0 0 8px 8px;
        font-weight: 600;
        font-size: 14px;
        transition: top 0.2s;
        text-decoration: none;
      }
      .skip-link:focus { top: 0; }
    </style>
  </head>

  <body class="min-h-screen flex flex-col overflow-x-hidden bg-zinc-50 dark:bg-zinc-950 text-zinc-900 transition-colors dark:text-zinc-100 selection:bg-emerald-500/30">
    <a href="#main-content" class="skip-link">{t("Skip to content", "Zum Inhalt springen")}</a>

    <div
      class="fixed inset-0 -z-10 dark:hidden"
      style="
        background-image:
          radial-gradient(circle at 20% 20%, var(--a2), transparent 45%),
          radial-gradient(circle at 80% 30%, var(--a1), transparent 45%),
          radial-gradient(circle at 50% 85%, var(--a3), transparent 50%),
          linear-gradient(-45deg, rgba(250,250,250,1), rgba(240,253,250,1), rgba(236,253,245,1), rgba(240,249,255,1));
      "
    ></div>

    <div
      class="fixed inset-0 -z-10 hidden dark:block"
      style="
        background-image:
          radial-gradient(circle at 20% 20%, var(--a2), transparent 45%),
          radial-gradient(circle at 80% 30%, var(--a1), transparent 45%),
          radial-gradient(circle at 50% 85%, var(--a3), transparent 50%),
          linear-gradient(-45deg, rgba(9,9,11,1), rgba(2,6,23,1), rgba(6,78,59,1), rgba(9,9,11,1));
      "
    ></div>

    <div class="pointer-events-none fixed right-[-520px] top-[-520px] z-0 hidden md:block">
      <div
        class="absolute inset-[-260px] rounded-full blur-[180px] opacity-80 dark:opacity-55"
        style="
          background:
            radial-gradient(circle at 35% 35%, var(--a2), transparent 62%),
            radial-gradient(circle at 70% 35%, var(--a1), transparent 64%),
            radial-gradient(circle at 45% 70%, var(--a3), transparent 66%);
        "
      ></div>

      <div class="opacity-75 dark:opacity-85 mix-blend-normal dark:mix-blend-screen dark:[filter:drop-shadow(0_0_90px_rgba(20,184,166,.22))]">
        <OrbHero size={1300} opacity={0.95} />
      </div>
    </div>


    <header
      class="fixed top-0 left-0 right-0 z-[999] border-b border-zinc-200/60 bg-zinc-50/80 backdrop-blur-md
             dark:border-zinc-800/60 dark:bg-zinc-950/80"
      role="banner"
    >
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
        <div class="flex items-center gap-4 min-w-0">

          <button
            id="mobileMenuBtn"
            type="button"
            class="md:hidden w-[30px] h-[30px] shrink-0 flex items-center justify-center rounded-lg hover:bg-white/10 transition"
            aria-label={t("Open menu", "Menü öffnen")}
            aria-expanded="false"
            aria-controls="mobileMenu"
          >
            <svg id="menuIconOpen" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            <svg id="menuIconClose" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>

          <div class="w-[30px] h-[30px] shrink-0 hidden md:block"></div>

          {showNavigation ? (
            <nav class="hidden md:flex flex-wrap items-center gap-x-4 gap-y-1 text-sm min-w-0" aria-label={t("Section navigation", "Abschnittsnavigation")}>
              <a class="spy-link" data-spy="journey" href={localePath("/", locale) + "#journey"}>{t("Journey", "Werdegang")}</a>
              <a class="spy-link" data-spy="volunteering" href={localePath("/", locale) + "#volunteering"}>{t("Volunteering", "Ehrenamt")}</a>
              <a class="spy-link" data-spy="exploring" href={localePath("/", locale) + "#exploring"}>{t("Exploring", "Erkundungen")}</a>
              <a class="spy-link" data-spy="skills" href={localePath("/", locale) + "#skills"}>{t("Skills", "Skills")}</a>
              <a class="spy-link" data-spy="latest-project" href={localePath("/", locale) + "#latest-project"}>{t("Latest Project", "Neuestes Projekt")}</a>
            </nav>
          ) : null}
        </div>

        <nav class="flex items-center gap-4 text-sm shrink-0" aria-label={t("Main navigation", "Hauptnavigation")}>
          <a class="hover:underline hidden md:inline" href={localePath("/", locale)}>
            {t("Home", "Startseite")}
          </a>

          <div class="relative group hidden md:block">
            <a class="hover:underline" href={localePath("/projects", locale)}>
              {t("Projects", "Projekte")}
            </a>

            <div class="absolute left-0 top-full hidden pt-2 group-hover:block group-focus-within:block">
              <div
                class="min-w-56 rounded-2xl border p-2 shadow-lg backdrop-blur"
                style="background: var(--glass); border-color: var(--glass-border);"
              >
                <a class="block rounded-xl px-3 py-2 text-sm hover:bg-white/10" href={localePath("/projects", locale)}>
                  {t("All projects", "Alle Projekte")}
                </a>

                <div class="my-2 h-px opacity-60" style="background: var(--glass-border);"></div>

                {tags.length ? (
                  <div class="max-h-64 overflow-auto no-scrollbar">
                    {tags.map((tg) => (
                      <a class="tag-dd-link block rounded-xl px-3 py-2 text-sm hover:bg-white/10" href={localePath(`/projects?tag=${encodeURIComponent(tg)}`, locale)}>
                        {tg}
                      </a>
                    ))}
                  </div>
                ) : (
                  <div class="px-3 py-2 text-xs text-zinc-700 dark:text-zinc-300">
                    {t("No tags yet", "Noch keine Tags")}
                  </div>
                )}
              </div>
            </div>
          </div>


          <div class="header-icon"><LanguageToggle locale={locale} currentPath={pathname} /></div>
          <div class="header-icon"><ThemeToggle /></div>
        </nav>
      </div>

      <!-- Mobile menu drawer -->
      <div
        id="mobileMenu"
        class="md:hidden hidden border-t border-zinc-200/60 dark:border-zinc-800/60"
        style="background: var(--glass); backdrop-filter: blur(20px);"
      >
        <nav class="flex flex-col px-4 py-4 gap-1 text-sm" aria-label={t("Mobile navigation", "Mobile Navigation")}>
          <a class="rounded-xl px-3 py-2.5 font-semibold hover:bg-white/10 transition" href={localePath("/", locale)}>
            {t("Home", "Startseite")}
          </a>
          <a class="rounded-xl px-3 py-2.5 font-semibold hover:bg-white/10 transition" href={localePath("/projects", locale)}>
            {t("Projects", "Projekte")}
          </a>

          {showNavigation ? (
            <>
              <div class="my-2 h-px opacity-40" style="background: var(--glass-border);"></div>
              <div class="px-3 py-1 text-[11px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 font-semibold">
                {t("Sections", "Bereiche")}
              </div>
              <a class="rounded-xl px-3 py-2.5 hover:bg-white/10 transition" href={localePath("/", locale) + "#journey"}>{t("Journey", "Werdegang")}</a>
              <a class="rounded-xl px-3 py-2.5 hover:bg-white/10 transition" href={localePath("/", locale) + "#volunteering"}>{t("Volunteering", "Ehrenamt")}</a>
              <a class="rounded-xl px-3 py-2.5 hover:bg-white/10 transition" href={localePath("/", locale) + "#exploring"}>{t("Exploring", "Erkundungen")}</a>
              <a class="rounded-xl px-3 py-2.5 hover:bg-white/10 transition" href={localePath("/", locale) + "#skills"}>{t("Skills", "Skills")}</a>
              <a class="rounded-xl px-3 py-2.5 hover:bg-white/10 transition" href={localePath("/", locale) + "#latest-project"}>{t("Latest Project", "Neuestes Projekt")}</a>
            </>
          ) : null}
        </nav>
      </div>
    </header>


    <main id="main-content" class="relative z-10 mx-auto max-w-5xl px-4 pt-24 pb-10 flex-1 w-full overflow-hidden md:overflow-visible" role="main">
      <slot />
    </main>

    <footer class="mt-10 pb-10 flex justify-center w-full px-4" role="contentinfo">
      <div class="inline-block rounded-2xl px-5 py-3 text-sm font-semibold text-center text-zinc-900 dark:text-zinc-100 bg-white/90 dark:bg-zinc-950/80 border border-zinc-200/70 dark:border-zinc-800/70">
        &copy; {new Date().getFullYear()} Your Name | {t("All rights reserved", "Alle Rechte vorbehalten")}
        <LikeFooter />
      </div>
    </footer>

    <script>
      function initScrollSpy() {
        const links = Array.from(document.querySelectorAll(".spy-link[data-spy]"));
        if (!links.length) return;

        const ids = links.map((a) => a.getAttribute("data-spy")).filter(Boolean);
        const sections = ids.map((id) => document.getElementById(id)).filter(Boolean);
        if (!sections.length) return;

        const setActive = (id) => {
          links.forEach((a) => a.classList.toggle("is-active", a.getAttribute("data-spy") === id));
        };

        const hash = (location.hash || "").replace("#", "");
        if (hash && ids.includes(hash)) setActive(hash);

        const obs = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => (b.intersectionRatio || 0) - (a.intersectionRatio || 0))[0];

            if (visible?.target?.id) setActive(visible.target.id);
          },
          { threshold: [0.25, 0.4, 0.55] }
        );

        sections.forEach((s) => obs.observe(s));

        window.addEventListener("hashchange", () => {
          const h = (location.hash || "").replace("#", "");
          if (h && ids.includes(h)) setActive(h);
        });
      }

      function getTimelineList() {
        return document.getElementById("timeline");
      }

      function updateJourneyButtonText(open) {
        const btn = document.getElementById("journeyToggle");
        if (!btn) return;
        const locale = document.documentElement.lang || "en";
        const text = open
          ? (locale === "de" ? "Weniger anzeigen" : "Show less")
          : (locale === "de" ? "Mehr anzeigen" : "Show more");
        const span = btn.querySelector("span");
        if (span) span.textContent = text;
        else btn.textContent = text;
      }

      function applyJourney(open) {
        const btn = document.getElementById("journeyToggle");
        const list = getTimelineList();
        if (!btn || !list) return;

        const extras = Array.from(list.querySelectorAll(".journey-extra"));
        btn.classList.toggle("hidden", extras.length === 0);

        extras.forEach((el) => el.classList.toggle("hidden", !open));
        updateJourneyButtonText(open);
      }

      window.__journeyOpen = window.__journeyOpen ?? false;

      function initJourneyUI() {
        updateJourneyButtonText(window.__journeyOpen);
        applyJourney(window.__journeyOpen);
      }

      document.addEventListener("click", (e) => {
        const btn = e.target?.closest?.("#journeyToggle");
        if (!btn) return;
        window.__journeyOpen = !window.__journeyOpen;
        applyJourney(window.__journeyOpen);
      });

      document.addEventListener("DOMContentLoaded", () => {
        initScrollSpy();
        initJourneyUI();
      });

      document.addEventListener("astro:page-load", () => {
        initScrollSpy();
        initJourneyUI();
      });
    </script>

    <script src="../scripts/toggles.js"></script>
    <script is:inline>
      const run = () => window.initToggles?.();
      document.addEventListener("DOMContentLoaded", run);
      document.addEventListener("astro:page-load", run);
    </script>

    <script is:inline>
      function initMobileMenu() {
        const btn = document.getElementById("mobileMenuBtn");
        const menu = document.getElementById("mobileMenu");
        const iconOpen = document.getElementById("menuIconOpen");
        const iconClose = document.getElementById("menuIconClose");
        if (!btn || !menu) return;

        function toggle() {
          const isOpen = !menu.classList.contains("hidden");
          menu.classList.toggle("hidden", isOpen);
          btn.setAttribute("aria-expanded", String(!isOpen));
          if (iconOpen) iconOpen.classList.toggle("hidden", !isOpen);
          if (iconClose) iconClose.classList.toggle("hidden", isOpen);
        }

        function close() {
          menu.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
          if (iconOpen) iconOpen.classList.remove("hidden");
          if (iconClose) iconClose.classList.add("hidden");
        }

        btn.addEventListener("click", toggle);
        menu.querySelectorAll("a").forEach(function(a) { a.addEventListener("click", close); });
      }

      document.addEventListener("DOMContentLoaded", initMobileMenu);
      document.addEventListener("astro:page-load", initMobileMenu);
    </script>
  </body>
</html>
