---
const {
  label = "Like",
  thanks = "Thank you!",
} = Astro.props;
---

<button id="likeBtn" class="likeBtn" type="button" aria-label={label} title={label}>
  <span id="heart" class="heart" aria-hidden="true">♡</span>
  <span id="likeCount" class="count">0</span>

  <span id="thanks" class="thanks" role="status" aria-live="polite" hidden>
    {thanks}
  </span>
</button>


<script is:inline>
  const likedKey = "liked_site_v1";
  const countKey = "liked_site_count_v1";

  async function initLikeFooter() {
    const btn = document.getElementById("likeBtn");
    const countEl = document.getElementById("likeCount");
    const heartEl = document.getElementById("heart");
    const thanksEl = document.getElementById("thanks");
    if (!btn || !countEl || !heartEl || !thanksEl) return;

    const refresh = () => {
      const current = Number(localStorage.getItem(countKey) || "0");
      countEl.textContent = String(current);
      if (localStorage.getItem(likedKey)) heartEl.textContent = "♥";
    };

    if (!btn.dataset.bound) {
      btn.addEventListener("click", () => {
        if (localStorage.getItem(likedKey)) return;

        btn.classList.add("pop");
        const next = Number(localStorage.getItem(countKey) || "0") + 1;
        localStorage.setItem(countKey, String(next));
        countEl.textContent = String(next);
        localStorage.setItem(likedKey, "1");
        heartEl.textContent = "♥";
        thanksEl.hidden = false;
        thanksEl.classList.add("show");

        setTimeout(() => btn.classList.remove("pop"), 350);
        setTimeout(() => {
          thanksEl.classList.remove("show");
          thanksEl.hidden = true;
        }, 1600);
      });

      btn.dataset.bound = "1";
    }

    refresh();
  }

  document.addEventListener("DOMContentLoaded", initLikeFooter);
  document.addEventListener("astro:page-load", initLikeFooter);
</script>

<style>
  .likeBtn{
    margin-left: 12px;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: 9999px;
  }

  .thanks{
    position: absolute;
    left: 50%;
    bottom: calc(100% + 8px);
    transform: translateX(-50%) translateY(6px);
    opacity: 0;
    pointer-events: none;

    white-space: nowrap;
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 9999px;
    background: rgba(0,0,0,.75);
    color: #fff;

    transition: opacity .2s ease, transform .2s ease;
  }
  .thanks.show{
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }


  .heart{
    font-size: 20px;
    line-height: 1;
    transform-origin: center;
  }

  .count{
    font-size: 14px;
  }

  .likeBtn.pop .heart{
    animation: pop .35s ease;
  }

  @keyframes pop{
    0%{ transform: scale(1); }
    50%{ transform: scale(1.35); }
    100%{ transform: scale(1); }
  }
</style>
