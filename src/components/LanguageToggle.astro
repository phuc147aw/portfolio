---
// SPDX-License-Identifier: MIT
import { getAlternatePath } from "../utils/i18n";

const { locale = "en", currentPath = "/" } = Astro.props;
const alt = getAlternatePath(currentPath);
---
<a
  id="langBtn"
  href={alt.path}
  class="rounded-xl border px-3 py-2 text-xs font-semibold transition hover:scale-[1.03]
         border-zinc-200 bg-zinc-50/20 text-zinc-900 backdrop-blur
         dark:border-zinc-700 dark:bg-zinc-950/25 dark:text-zinc-100"
  aria-label={locale === "vi" ? "Switch to English" : "Switch to Vietnamese"}
  title={locale === "vi" ? "Switch to English" : "Switch to Vietnamese"}
  data-locale-switch={alt.locale}
  onclick={`localStorage.setItem('locale-pref','${alt.locale}')`}
>
  {locale === "vi" ? "EN" : "VI"}
</a>
