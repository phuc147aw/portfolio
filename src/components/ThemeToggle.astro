<button
  id="themeBtn"
  class="rounded-xl border px-3 py-2 text-sm transition hover:scale-[1.03]
         border-zinc-200 bg-zinc-50/40 text-zinc-900 shadow-sm backdrop-blur
         dark:border-zinc-700 dark:bg-zinc-950/30 dark:text-zinc-100"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <span class="dark:hidden">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="inline">
      <path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z" stroke="currentColor" stroke-width="2"/>
      <path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M19 19l-1.5-1.5M19 5l-1.5 1.5M5 19l1.5-1.5"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </span>

  <span class="hidden dark:inline">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" class="inline">
      <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z" stroke="currentColor" stroke-width="2"/>
    </svg>
  </span>
</button>
