---
// SPDX-License-Identifier: MIT
const { title = "Skills" } = Astro.props;

const groups = [
  { name: "Automation", items: ["n8n", "REST APIs", "Webhooks", "ETL", "Notifications"] },
  { name: "Infrastructure", items: ["Docker", "Linux", "Nginx", "Reverse Proxy", "Backups"] },
  { name: "Monitoring", items: ["Prometheus", "Grafana", "Uptime checks", "Logs"] },
  { name: "Development", items: ["Node.js", "TypeScript", "Python", "Git"] },
];
---

<section class="rounded-[28px] p-6 shadow-sm backdrop-blur"
         style="background: var(--glass); border: 1px solid var(--glass-border);">
  <div class="flex items-center justify-between gap-3">
    <h2 class="text-lg font-semibold">{title}</h2>
  </div>

  <div class="mt-5 grid gap-4 md:grid-cols-2">
    {groups.map((g) => (
      <article class="rounded-2xl border p-4"
               style="border-color: var(--glass-border); background: rgba(255,255,255,.10);">
        <div class="font-semibold">{g.name}</div>
        <div class="mt-3 flex flex-wrap gap-1.5">
          {g.items.map((t) => (
            <span class="rounded-full border px-2.5 py-0.5 text-[11px]"
                  style="border-color: var(--glass-border); background: rgba(255,255,255,.08);">
              {t}
            </span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
