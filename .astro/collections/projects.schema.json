{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "pid": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "title": {
          "type": "string"
        },
        "title_de": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "description_de": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "category": {
          "type": "string",
          "enum": [
            "automation",
            "tooling",
            "open-source",
            "integration",
            "research",
            "self-hosted",
            "other"
          ],
          "default": "other"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "label",
              "url"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "image": {
          "type": "string"
        },
        "coverImage": {
          "type": "string"
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "slug": {
          "type": "string"
        },
        "ready": {
          "type": "boolean",
          "default": true
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "pid",
        "title",
        "description",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}